# Copy to .env and fill in real values

# PostgreSQL (Railway에서 자동 제공)
DATABASE_URL=postgresql://postgres:password@localhost:5432/places_dev

# Claude Haiku via Vertex AI — 캡션 → 장소 추출
# Google Cloud 프로젝트 ID (Vertex AI 사용 시 필수)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Vertex AI 리전 (Claude 지원 리전: us-east5)
VERTEX_REGION=us-east5
# Vertex AI 모델 ID
VERTEX_MODEL=claude-haiku-4-5@20251001
# Railway 배포 시: 서비스 계정 JSON 전체 내용을 이 변수에 붙여넣기
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
# 로컬 개발 시 폴백 (GOOGLE_CLOUD_PROJECT 없을 때 사용)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Places API — 주소/좌표 변환
GOOGLE_PLACES_API_KEY=AIza...

# Instagram 크롤링 계정 (Playwright 사용)
INSTAGRAM_USERNAME=your_instagram_account
INSTAGRAM_PASSWORD=your_instagram_password

# 파이프라인 수동 실행 엔드포인트 보호 (POST /pipeline/run)
ADMIN_SECRET=choose_a_strong_random_secret

# 허용 CORS 출처 (쉼표 구분)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# 크롤링 해시태그 (쉼표 구분, # 제외)
CRAWL_HASHTAGS=맛집,카페,맛스타그램
